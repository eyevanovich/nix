{
  "name": "pi-extension-uber-go-style",
  "version": "1.0.0",
  "description": "Uber Go Style Guide extension for Pi - injects Go style rules and runs gofmt/go vet/golangci-lint on edited Go files",
  "type": "module",
  "license": "MIT",
  "author": "Pi Extensions",
  "keywords": [
    "pi-mono",
    "pi-package",
    "extension",
    "go",
    "golang",
    "uber",
    "style-guide",
    "lint"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "standards",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^24.12.3",
    "typescript": "^5.9.3"
  }
}
